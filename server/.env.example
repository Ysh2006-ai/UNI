# MongoDB Connection
# Set to "memory" to use in-memory MongoDB (no external DB needed)
# Or use a MongoDB Atlas URI: mongodb+srv://user:pass@cluster.mongodb.net/uni
MONGO_URI=memory

# JWT Secret Key (change this in production!)
JWT_SECRET=uni-platform-secret-key-change-me-2026

# Server Port
PORT=5001

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
